[Unit]
Description=Snoke desktop tracker
After=graphical-session.target network-online.target
Wants=network-online.target
PartOf=graphical-session.target

[Service]
Type=simple
# Pass SNOKE_BACKEND, SNOKE_TOKEN via this file:
EnvironmentFile=%h/.config/snoke/tracker.env
ExecStart=%h/code/snoke/tracker/.venv/bin/snoke-tracker
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target

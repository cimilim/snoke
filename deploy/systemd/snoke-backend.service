[Unit]
Description=Snoke backend (FastAPI + Web-UI)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/code/snoke/backend
EnvironmentFile=%h/code/snoke/backend/.env
ExecStart=%h/code/snoke/backend/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=on-failure
RestartSec=3

[Install]
WantedBy=default.target
